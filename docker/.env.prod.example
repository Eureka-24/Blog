# ============================================
# 阿里云生产环境配置示例
# 使用方式: docker-compose -f docker-compose.blog.yml --env-file .env.prod up -d
# ============================================

# ============================================
# 基础设施配置
# ============================================

# PostgreSQL 配置
POSTGRES_PASSWORD=your_secure_postgres_password
DB_PASSWORD=your_secure_blog_password

# Meilisearch 配置
MEILI_MASTER_KEY=your_secure_meili_key

# ============================================
# 应用服务配置
# ============================================

# 数据库连接（如果在同一服务器使用 host.docker.internal）
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=blog
DB_USER=blog

# Redis 连接
REDIS_HOST=host.docker.internal
REDIS_PORT=6379

# Meilisearch 连接
MEILI_HOST=http://host.docker.internal:7700

# JWT 配置（生产环境务必使用强密钥）
JWT_SECRET=your_very_secure_jwt_secret_at_least_32_characters_long

# ============================================
# 公开访问地址（重要：修改为您的域名）
# ============================================

# 前端 URL 配置
BLOG_URL=https://your-domain.com
ADMIN_URL=https://your-domain.com

# 公开 API URL（前端通过 Nginx 访问）
PUBLIC_API_URL=https://your-domain.com/api
PUBLIC_ADMIN_API_URL=https://your-domain.com/api/admin

# 内部 API URL（服务端渲染或调试用）
WEB_API_URL=https://your-domain.com/api
ADMIN_API_URL=https://your-domain.com/api/admin

# ============================================
# 阿里云 OSS 配置（如使用）
# ============================================
ALIYUN_ACCESS_KEY_ID=your_access_key
ALIYUN_ACCESS_KEY_SECRET=your_secret
ALIYUN_OSS_BUCKET=your_bucket
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
