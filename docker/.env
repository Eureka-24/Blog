# ============================================
# 统一配置文件
# 同时适用于 docker-compose.infra.yml 和 docker-compose.blog.yml
# 也适用于 docker-compose.local.yml
# ============================================

# ============================================
# 基础设施配置（docker-compose.infra.yml 使用）
# ============================================

# PostgreSQL 配置
POSTGRES_PASSWORD=postgres123
DB_PASSWORD=blog123

# Redis 配置
# REDIS_PASSWORD=  # 可选，默认无密码

# Meilisearch 配置
MEILI_MASTER_KEY=your_search_master_key

# ============================================
# 应用服务配置（docker-compose.yml 使用）
# ============================================

# 数据库连接（应用连接基础设施）
DB_HOST=host.docker.internal
DB_PORT=5432
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
MEILI_HOST=http://host.docker.internal:7700

# JWT 配置（请使用强密钥，生产环境建议32位以上随机字符串）
JWT_SECRET=dasdasscxzsadsadsaxzczxsadsadasczxsad

# 前端 URL 配置（通过Nginx代理访问）
BLOG_URL=http://localhost/blog
ADMIN_URL=http://localhost/admin

# 公开 API URL 配置（用于前端构建，通过 Nginx 代理）
PUBLIC_API_URL=http://localhost/api
PUBLIC_ADMIN_API_URL=http://localhost/api/admin

# 内部 API URL 配置（用于服务端渲染或直接访问后端）
WEB_API_URL=http://localhost:8080
ADMIN_API_URL=http://localhost:8081

# ============================================
# 阿里云 OSS 配置（可选）
# ============================================
ALIYUN_ACCESS_KEY_ID=your_access_key
ALIYUN_ACCESS_KEY_SECRET=your_secret
ALIYUN_OSS_BUCKET=your_bucket
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
