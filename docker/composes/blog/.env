# ============================================
# 博客应用服务专用配置
# 用于 docker-compose.yml (blog)
# 注意：此配置用于 Docker 容器间通信
# ============================================

# 数据库连接配置（通过 infra-net 连接基础设施容器）
DB_HOST=postgres
DB_PORT=5432
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=blog123

# Redis 连接配置（通过 infra-net 连接）
REDIS_HOST=redis
REDIS_PORT=6379

# Meilisearch 连接配置（通过 infra-net 连接）
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=masterSearchKey

# JWT 配置（请使用强密钥，生产环境建议32位以上随机字符串）
JWT_SECRET=dasdasscxzsadsadsaxzczxsadsadasczxsad

# 导航前端 URL 配置
# 通过 Nginx 代理访问，使用 /blog 和 /admin 路径
BLOG_URL=http://localhost/blog
ADMIN_URL=http://localhost/blog/admin

# 公开 API URL 配置（用于前端构建，通过 Nginx 代理）
# 注意：前端代码中 endpoint 已包含 /api/ 前缀，所以这里配置到 /blog 即可
# 例如：前端请求 /api/articles -> 完整路径 http://localhost/blog/api/articles
PUBLIC_API_URL=http://localhost/blog
PUBLIC_ADMIN_API_URL=http://localhost/blog

# 内部 API URL 配置（用于服务端渲染）
WEB_API_URL=http://web-api:8080
ADMIN_API_URL=http://admin-api:8081

# 阿里云 OSS 配置（可选）
ALIYUN_ACCESS_KEY_ID=your_access_key
ALIYUN_ACCESS_KEY_SECRET=your_secret
ALIYUN_OSS_BUCKET=your_bucket
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
